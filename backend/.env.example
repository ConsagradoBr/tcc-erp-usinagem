# Opção 1: URL única, recomendada para deploy e testes
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/postgres?sslmode=require

# Opção 2: campos separados
DB_USER=seu_usuario_supabase
DB_PASS=sua_senha
DB_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

JWT_SECRET_KEY=sua_chave_jwt
SECRET_KEY=sua_secret_key
BOOTSTRAP_ADMIN_TOKEN=token_unico_para_primeiro_admin_em_producao
JWT_ACCESS_TOKEN_MINUTES=30
MAX_CONTENT_LENGTH=16777216
BACKUP_MAX_BYTES=52428800
AMP_RUNTIME_DIR=/caminho/fora/do/repositorio/amp-runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
APP_ENV=development
