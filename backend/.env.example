# Exemplo seguro para producao/deploy.
# Para desenvolvimento local rapido, troque APP_ENV para development.

# Opcao 1: URL unica, recomendada para deploy e testes
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/postgres?sslmode=require

# Opcao 2: campos separados
DB_USER=seu_usuario_supabase
DB_PASS=sua_senha
DB_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

JWT_SECRET_KEY=troque_por_uma_chave_jwt_com_32_chars_minimo
SECRET_KEY=troque_por_uma_secret_key_com_32_chars_minimo
BOOTSTRAP_ADMIN_TOKEN=troque_por_um_token_bootstrap_longo_e_unico
JWT_ACCESS_TOKEN_MINUTES=30
MAX_CONTENT_LENGTH=16777216
BACKUP_MAX_BYTES=52428800
AMP_RUNTIME_DIR=/caminho/fora/do/repositorio/amp-runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
CORS_ORIGINS=https://seu-frontend.vercel.app
APP_ENV=production
